{
  "name": "emtypyie-cli",
  "version": "1.3.3",
  "description": "EMTYPYIE CLI — Run emtypyie projects from your terminal with ease",
  "main": "cli.js",
  "bin": {
    "emtypyie": "cli.js"
  },
  "scripts": {
    "start": "node cli.js",
    "gui": "node gui/server.js",
    "prepublishOnly": "node -e \"console.log('Publishing emtypyie-cli v' + require('./package.json').version)\""
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
