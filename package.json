{
  "name": "emtypyie-cli",
  "version": "2.0.6",
  "description": "EMTYPYIE CLI — Run emtypyie projects from your terminal with ease",
  "main": "cli.js",
  "bin": {
    "emtypyie": "cli.js"
  },
  "scripts": {
    "start": "node cli.js",
    "gui": "node gui/server.js",
    "build": "pkg cli.js --targets node18-win-x64 --output dist/emtypyie.exe",
    "prepublishOnly": "node -e \"console.log('Publishing emtypyie-cli v' + require('./package.json').version)\""
  },
  "pkg": {
    "assets": [
      "commands/**/*",
      "projects/**/*",
      "gui/**/*",
      "node_modules/chalk/**/*"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myrachane/emtypyie-cli.git"
  },
  "keywords": [
    "emtypyie",
    "cli",
    "project-manager",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
